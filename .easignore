# Force EAS to not use cache
.expo/
node_modules/

# Documentation and markdown files (not needed for build)
*.md
docs/
.cursor/

# Test files (not needed for build)
__tests__/
*.test.ts
*.test.tsx
*.test.js
*.test.jsx
jest.config.js
jest.setup.js

# Development and debug files
# Note: src/debug/ is needed for production builds (aiDebugConfig is imported in _layout.tsx)
# Note: components/dev/ is needed for production builds (LogViewer is imported in DevToolsModal.tsx)
# Only exclude root-level dev/ directory, not components/dev/ (use /dev/ to match root only)
/dev/
src/dev/
test_*.js
*.crash

# Build artifacts
build/
dist/
*.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Scripts (not needed for build)
# Keep fix-podspec.js and preflight-check.js as they're needed for builds
scripts/build-and-submit-testflight.*
scripts/eas-build-on-success.sh
scripts/polyfill-toReversed.js
scripts/run-tests.ts
scripts/testScenarioFix.ts
scripts/verify-podspec-patches.js
scripts/verifyIAPConfig.ts
scripts/README_BUILD_SCRIPTS.md
*.sh
*.ps1


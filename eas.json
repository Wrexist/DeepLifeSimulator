{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "production": {
      "ios": { 
        "resourceClass": "m-medium",
        "autoIncrement": false,
        "buildConfiguration": "Release",
        "image": "macos-sequoia-15.1-xcode-16.1",
        "env": {
          "RCT_NEW_ARCH_ENABLED": "0",
          "FOLLY_NO_CONFIG": "1",
          "FOLLY_MOBILE": "1",
          "FOLLY_USE_LIBCPP": "1",
          "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
        },
        "simulator": false
      },
      "android": {
        "resourceClass": "medium",
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "env": {
          "RCT_NEW_ARCH_ENABLED": "1"
        }
      }
    },
    "preview": {
      "developmentClient": true,
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "S3U8B8HH96",
        "ascAppId": "6749675615",
        "language": "en-US"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}

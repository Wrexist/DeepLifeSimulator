{
  "name": "life-simulator",
  "main": "./app/entry.ts",
  "version": "2.3.5",
  "private": true,
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest lib/",
    "test:integration": "jest lib/progress/__tests__/saveLoad.test.ts",
    "test:e2e": "jest __tests__/e2e/",
    "test:performance": "jest __tests__/performance/",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:comprehensive": "ts-node scripts/run-tests.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit --pretty",
    "preflight:ios": "node scripts/preflight-check.js --platform ios",
    "preflight": "node scripts/preflight-check.js --platform ios",
    "preflight:baseline": "node scripts/preflight-check.js --baseline",
    "preflight:baseline:quick": "node scripts/preflight-check.js --baseline --quick-baseline",
    "preflight:quick": "npm run type-check",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "postinstall": "node scripts/fix-podspec.js",
    "android": "expo run:android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-in-app-purchases": "^14.5.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "lucide-react-native": "^0.475.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^14.6.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@playwright/test": "^1.55.0",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-config-expo": "~10.0.0",
    "expo-build-properties": "~1.0.10",
    "jest": "~29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "braces": ">=3.0.3",
    "form-data": ">=2.5.4",
    "js-yaml": ">=4.1.1",
    "node-notifier": ">=8.0.1",
    "tough-cookie": ">=4.1.3",
    "@sentry/browser": ">=7.119.1",
    "@sentry/react": ">=7.119.1",
    "@sentry/react-native": ">=5.34.0",
    "react": "19.1.0"
  },
  "resolutions": {
    "react": "19.1.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }

    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.19",

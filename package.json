  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@playwright/test": "^1.55.0",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-native": "^0.72.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "braces": ">=3.0.3",
    "form-data": ">=2.5.4",
    "js-yaml": ">=4.1.1",
    "node-notifier": ">=8.0.1",
    "tough-cookie": ">=4.1.3"

# DeepLife Simulator - Environment Variables
# Copy this file to .env.local and fill in your values

# Cloud Save Backend URL (optional)
EXPO_PUBLIC_CLOUD_SAVE_URL=https://your-backend-url.com/api

# Save Integrity (required for production security)
# Required in production. Configure this as an EAS secret:
# eas secret:create --scope project --name EXPO_PUBLIC_SAVE_HMAC_KEY --value "<long-random-secret>"
# Keep this value stable across releases to avoid save signature mismatches.
EXPO_PUBLIC_SAVE_HMAC_KEY=replace-with-long-random-secret
# Production should keep this true (default). Set false only for controlled migrations.
EXPO_PUBLIC_REQUIRE_SIGNED_SAVES=true
# Emergency migration toggles (keep false in production by default).
EXPO_PUBLIC_ALLOW_UNSIGNED_LEGACY_SAVES=false
EXPO_PUBLIC_ALLOW_WEAK_SAVE_MIGRATION=false

# Feature Flags
# Set to 'true' to enable "Boring Build" mode (disables optional features for stability)
EXPO_PUBLIC_BORING_BUILD=false

# In-App Purchases (enabled by default when not in boring build mode)
EXPO_PUBLIC_ENABLE_IAP=true

# AdMob Ads (currently disabled)
EXPO_PUBLIC_ENABLE_ADMOB=false
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-2286247955186424~3290819490
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-2286247955186424~3290819490

# Analytics/Crash Reporting (currently disabled)
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# App Tracking Transparency - iOS only
EXPO_PUBLIC_ENABLE_ATT=true

# Push Notifications
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# IAP Receipt Verification (required for secure in-app purchases)
# Server endpoint for verifying Apple/Google receipts
EXPO_PUBLIC_IAP_VERIFY_URL=
# Auth token for receipt verification server
EXPO_PUBLIC_IAP_VERIFY_TOKEN=

# Cloud Sync Authentication Token
EXPO_PUBLIC_CLOUD_AUTH_TOKEN=

# Cloud Sync: require authentication for cloud saves (default: true)
# WARNING: Setting to false disables auth for cloud save uploads — security risk in production
EXPO_PUBLIC_CLOUD_REQUIRE_AUTH=true

# IAP: allow legacy local entitlement checks without server verification (default: false)
# WARNING: Setting to true bypasses receipt verification — only for testing/migration
EXPO_PUBLIC_ALLOW_LEGACY_LOCAL_IAP_ENTITLEMENTS=false

# Deprecated: use EXPO_PUBLIC_SAVE_HMAC_KEY instead
# EXPO_PUBLIC_SAVE_SIGNATURE_KEY=

# AdMob Ad Unit IDs (production - falls back to test IDs if not set)
# EXPO_PUBLIC_ADMOB_BANNER_IOS=
# EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
# EXPO_PUBLIC_ADMOB_REWARDED_IOS=
# EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=

# Build Number (used by app.config.js, auto-set by CI/EAS)
# BUILD_NUMBER=1

# Android Release Signing (for production builds)
# KEYSTORE_FILE=path/to/release.keystore
# KEYSTORE_PASSWORD=your_keystore_password
# KEY_ALIAS=your_key_alias
# KEY_PASSWORD=your_key_password

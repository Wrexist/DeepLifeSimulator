{
  "expo": {
    "name": "DeepLife Simulator",
    "slug": "deeplife-simulator",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/55bb8510-7ba6-4ec5-9174-cc370f5f6fdb"
    },
    "extra": {
      "eas": {
        "projectId": "55bb8510-7ba6-4ec5-9174-cc370f5f6fdb"
      }
    },
    "owner": "isacm",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "The ultimate life simulation game where every choice matters",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deeplife.simulator",
      "buildNumber": "12",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to the camera so you can upload a profile picture.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library so you can select images.",
        "NSMicrophoneUsageDescription": "This app needs access to the microphone so you can record audio.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.deeplife.simulator",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
